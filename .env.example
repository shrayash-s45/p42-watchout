# ─────────────────────────────────────────────────────────────────────────────
# Legal DD Tester — environment template.
# Copy to `.env` and fill in. NEVER commit `.env`. All values below are SECRET.
# ─────────────────────────────────────────────────────────────────────────────

# Server
PORT=3000

# Render the UI from local fixtures instead of calling either API.
# Leave true while you wire up keys; flip to false to make real calls.
USE_FIXTURES=true

# ── Probe42 ──────────────────────────────────────────────────────────────────
# Secret x-api-key. Sandbox key resolves ~150 fixed test entities; production
# key resolves any real CIN.
PROBE42_API_KEY=
# "sandbox" | "production"
PROBE42_ENV=sandbox
PROBE42_API_VERSION=1.3

# ── Watchout Investors (PRIME) ───────────────────────────────────────────────
# Two-step AES-encrypted API. Userid/Password/AES key are provided separately
# per environment — never reuse the sample credentials from the API PDF.
WATCHOUT_USERID=
WATCHOUT_PASSWORD=
# AES-256 key. 32 bytes once decoded. Set the encoding below to match what you
# were given: "utf8" (32-char string), "hex" (64 hex chars), or "base64".
WATCHOUT_AES_KEY=
WATCHOUT_AES_KEY_ENCODING=utf8
# "test" | "production" (both currently share the same host; kept for parity)
WATCHOUT_ENV=test
